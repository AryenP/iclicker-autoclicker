{
  "manifest_version": 3,
  "name": "AutoClicker",
  "version": "1.0",
  "description": "Detects screen changes and randomly clicks an option.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
