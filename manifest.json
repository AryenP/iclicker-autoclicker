{
  "manifest_version": 3,
  "name": "iClicker AutoClicker",
  "version": "1.0",
  "description": "Record exact click positions on any webpage and replay them in sequence. Perfect for iClicker quizzes, surveys, and repetitive tasks",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
